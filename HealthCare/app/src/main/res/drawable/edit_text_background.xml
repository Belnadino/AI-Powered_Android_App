<!-- res/drawable/edit_text_background.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- White background -->
    <solid android:color="@color/colorSurface"/>

    <!-- Light gray border -->
    <stroke
        android:width="2dp"
        android:color="#CCCCCC"/>

    <!-- Rounded corners -->
    <corners android:radius="12dp"/>

    <!-- Optional padding -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp"/>
</shape>
