<!-- res/drawable/button_border.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color -->
    <solid android:color="@color/colorSurface"/> <!-- usually white -->

    <!-- Border -->
    <stroke
        android:width="2dp"
        android:color="@color/colorPrimary"/> <!-- purple border -->

    <!-- Rounded corners -->
    <corners android:radius="12dp"/>

    <!-- Optional padding -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp"/>
</shape>
