<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
       android:background="@color/colorBackground"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/colorPrimary"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="Settings"
        app:titleTextColor="@color/colorOnPrimary" />

    <!-- Body -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="?android:attr/dividerVertical"
            android:dividerPadding="20dp"
            android:orientation="vertical"
            android:showDividers="middle">

            <!-- FONT SIZE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/font_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Font Size"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/font_size_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/font_small"
                        android:text="Small"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="18sp" />

                    <RadioButton
                        android:id="@+id/font_medium"
                        android:checked="true"
                        android:text="Medium"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="18sp" />

                    <RadioButton
                        android:id="@+id/font_large"
                        android:text="Large"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="18sp" />
                </RadioGroup>
            </LinearLayout>

            <!-- SOUND INPUT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/sound_input_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enable Sound Input"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/sound_input_group"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/sound_input_yes"
                        android:text="Yes"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="18sp" />

                    <RadioButton
                        android:id="@+id/sound_input_no"
                        android:layout_marginStart="24dp"
                        android:checked="true"
                        android:text="No"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="18sp" />
                </RadioGroup>
            </LinearLayout>

            <!-- SOUND ALERT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:id="@+id/sound_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Enable Sound Alert"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_sound"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <!-- VIBRATION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:id="@+id/vibration_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Enable Vibration"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_vibration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <!-- SAVE BUTTON -->
            <Button
                android:id="@+id/btn_save_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:backgroundTint="?attr/colorPrimary"
                android:padding="16dp"
                android:text="Save Settings"
                android:textColor="?attr/colorOnPrimary"
                android:textSize="20sp"
                android:background="@drawable/button_border"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
